<Window x:Class="WpfApp1.MainWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="yt-dlpGUI-lite"
Height="720"
Width="520"
AllowDrop="True"
Drop="Window_Drop">

<Grid Margin="20">

<StackPanel>

<TextBlock Text="yt-dlpGUI-lite"
FontSize="22"
FontWeight="Bold"
Margin="0,0,0,10"/>

<TextBox x:Name="UrlBox"
Height="32"
Margin="0,0,0,10"
TextChanged="UrlBox_TextChanged"/>

<Image x:Name="ThumbnailImage"
Height="160"
Stretch="Uniform"
Margin="0,0,0,10"/>

<TextBlock x:Name="TitleText"
Text="動画タイトル"
TextWrapping="Wrap"/>

<TextBlock x:Name="ChannelText"
Text="チャンネル: -"/>

<TextBlock x:Name="ViewsText"
Text="再生回数: -"/>

<TextBlock x:Name="SizeText"
Text="サイズ: -"/>

<TextBlock x:Name="DurationText"
Text="動画時間: -"
Margin="0,0,0,10"/>

<StackPanel Orientation="Horizontal">

<RadioButton x:Name="Mp4Radio"
Content="MP4"
IsChecked="True"
Margin="0,0,20,0"/>

<RadioButton x:Name="Mp3Radio"
Content="MP3"/>

</StackPanel>

<TextBlock Text="画質選択" Margin="0,10,0,0"/>

<ComboBox x:Name="QualityBox" SelectedIndex="0">
<ComboBoxItem Content="1080p"/>
<ComboBoxItem Content="720p"/>
</ComboBox>

<StackPanel Orientation="Horizontal" Margin="0,10,0,10">

<TextBox x:Name="FolderBox"
Width="300"
Height="30"/>

<Button Content="Browse"
Width="90"
Margin="5,0,0,0"
Click="Browse_Click"/>

</StackPanel>

<Button Content="Download"
Height="40"
Click="Download_Click"/>

<ProgressBar x:Name="ProgressBar"
Height="20"
Margin="0,10,0,5"/>

<TextBlock x:Name="StatusText"
Text="Idle"/>

<TextBlock x:Name="SpeedText"
Text="速度: -"/>

<Button Content="Update yt-dlp"
Height="30"
Margin="0,10,0,5"
Click="Update_Click"/>

<CheckBox x:Name="DarkModeToggle"
Content="Dark Mode"
Checked="DarkModeToggle_Checked"
Unchecked="DarkModeToggle_Checked"/>

</StackPanel>

</Grid>
</Window>